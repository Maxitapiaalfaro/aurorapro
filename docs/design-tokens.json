    "lineHeights": {
      "tight": "1.3",
      "relaxed": "1.6",
      "normal": "1.5"
    },
    "messageText": {
      "description": "User-customizable message text sizes",
      "sm": {
        "fontSize": "0.875rem",
        "lineHeight": "1.5rem"
      },
      "base": {
        "fontSize": "1rem",
        "lineHeight": "1.6rem"
      },
      "lg": {
        "fontSize": "1.125rem",
        "lineHeight": "1.75rem"
      },
      "xl": {
        "fontSize": "1.25rem",
        "lineHeight": "1.875rem"
      }
    }
  },
  "animation": {
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "inOut": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "duration": {
      "fast": "150ms",
      "normal": "300ms",
      "slow": "600ms"
    },
    "keyframes": {
      "cursorBlink": {
        "description": "Natural, slow keyboard cursor animation",
        "steps": {
          "0%": { "opacity": 1 },
          "45%": { "opacity": 1 },
          "50%": { "opacity": 0 },
          "95%": { "opacity": 0 },
          "100%": { "opacity": 1 }
        },
        "duration": "1.2s",
        "timing": "ease-in-out",
        "iteration": "infinite"
      },
      "gentlePulse": {
        "description": "Gentle pulsing animation for indicators",
        "steps": {
          "0%": { "opacity": 0.7, "transform": "scale(1)" },
          "50%": { "opacity": 1, "transform": "scale(1.05)" },
          "100%": { "opacity": 0.7, "transform": "scale(1)" }
        }
      },
      "slideUp": {
        "description": "Slide up animation for messages",
        "steps": {
          "0%": { "opacity": 0, "transform": "translateY(20px)" },
          "100%": { "opacity": 1, "transform": "translateY(0)" }
        },
        "duration": "0.6s",
        "timing": "ease-out"
      },
      "gentleGlow": {
        "description": "Gentle glow effect",
        "steps": {
          "0%": { "boxShadow": "0 0 0 0 rgba(59, 130, 246, 0)" },
          "50%": { "boxShadow": "0 0 0 4px rgba(59, 130, 246, 0.1)" },
          "100%": { "boxShadow": "0 0 0 0 rgba(59, 130, 246, 0)" }
        },
        "duration": "2s",
        "timing": "ease-in-out",
        "iteration": "infinite"
      },
      "accordionDown": {
        "description": "Accordion expand animation",
        "duration": "0.2s",
        "timing": "ease-out"
      },
      "accordionUp": {
        "description": "Accordion collapse animation",
        "duration": "0.2s",
        "timing": "ease-out"
      },
      "scrollHint": {
        "description": "Scroll hint indicator for mobile tables",
        "steps": {
          "0%": { "opacity": 0.3, "transform": "translateY(-50%) translateX(0)" },
          "50%": { "opacity": 0.7, "transform": "translateY(-50%) translateX(5px)" },
          "100%": { "opacity": 0.3, "transform": "translateY(-50%) translateX(0)" }
        },
        "duration": "2s",
        "timing": "ease-in-out",
        "iteration": "infinite"
      }
    }
  },
