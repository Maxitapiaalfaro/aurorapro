  "spacing": {
    "base": "8px",
    "description": "Base spacing unit (8px grid system)",
    "scale": {
      "0": "0px",
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
