      "20": "80px",
      "24": "96px"
    }
  },
  "borderRadius": {
    "base": "0.5rem",
    "description": "Base border radius (8px)",
    "scale": {
      "sm": "calc(0.5rem - 4px)",
      "md": "calc(0.5rem - 2px)",
      "lg": "0.5rem",
      "full": "9999px"
    }
  },
  "typography": {
    "fontFamilies": {
      "sans": {
        "value": "IBM Plex Sans, system-ui, -apple-system, sans-serif",
        "description": "Primary sans-serif font for UI",
        "weights": ["400", "600"],
        "variable": "--font-sans"
      },
      "serif": {
        "value": "IBM Plex Serif, Georgia, serif",
        "description": "Serif font for clinical content and emphasis",
        "weights": ["400", "600"],
        "variable": "--font-serif"
      }
    },
    "fontSizes": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem"
