        "desktop": "2rem"
      },
      "full": {
        "mobile": "0.375rem",
        "tablet": "2rem",
        "desktop": "2.5rem"
      }
    }
  },
  "effects": {
    "shadows": {
      "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "md": "0 1px 3px 0 rgba(0, 0, 0, 0.1)",
      "lg": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
      "xl": "0 10px 15px -3px rgba(0, 0, 0, 0.1)"
    },
    "backdrop": {
      "blur": "blur(8px)",
